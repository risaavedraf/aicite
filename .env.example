# AI Cite CLI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file itself!
#
# Phase 9 policy:
# - Canonical runtime namespace is CITE_*.
# - Legacy HARNESS_* vars are not auto-aliased by runtime code.
# - Canonical local DB filename is cite.db under CITE_DATA_DIR.

# ──────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────

# Runtime mode: public_packaged_demo | local_private_demo | production
# CITE_RUNTIME_MODE=local_private_demo

# Data directory for SQLite, indexes, and durable state
# CITE_DATA_DIR=/path/to/data

# Cache directory for temporary extraction data
# CITE_CACHE_DIR=/path/to/cache

# ──────────────────────────────────────────────
# Embedding Provider
# ──────────────────────────────────────────────

# Provider: gemini | openai-compatible (default)
CITE_EMBEDDING_PROVIDER=gemini

# Model ID
# Gemini: gemini-embedding-001 | gemini-embedding-2
# OpenAI: text-embedding-3-small | text-embedding-3-large
CITE_EMBEDDING_MODEL=gemini-embedding-001

# API key — one of these:
#   Gemini:  get free key at https://aistudio.google.com/apikey
#   OpenAI:  https://platform.openai.com/api-keys
CITE_EMBEDDING_API_KEY=

# Custom endpoint (only for openai-compatible, leave empty for default)
# CITE_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings

# Embedding request timeout in seconds
# CITE_EMBEDDING_TIMEOUT=30

# ──────────────────────────────────────────────
# Ingest Pipeline
# ──────────────────────────────────────────────

# Maximum file size in bytes (default: 50MB)
# CITE_MAX_FILE_SIZE=52428800

# Chunk size in characters (default: 1000)
# CITE_CHUNK_SIZE=1000

# Chunk overlap in characters (default: 200)
# CITE_CHUNK_OVERLAP=200

# ──────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────

# Default retrieval top-k (1-10)
# CITE_TOP_K=5
