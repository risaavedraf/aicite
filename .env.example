# AI Harness CLI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file itself!

# ──────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────

# Runtime mode: public_packaged_demo | local_private_demo | production
# HARNESS_RUNTIME_MODE=local_private_demo

# Data directory for SQLite, indexes, and durable state
# HARNESS_DATA_DIR=/path/to/data

# Cache directory for temporary extraction data
# HARNESS_CACHE_DIR=/path/to/cache

# ──────────────────────────────────────────────
# Embedding Provider
# ──────────────────────────────────────────────

# Provider: gemini | openai-compatible (default)
HARNESS_EMBEDDING_PROVIDER=gemini

# Model ID
# Gemini: gemini-embedding-001 | gemini-embedding-2
# OpenAI: text-embedding-3-small | text-embedding-3-large
HARNESS_EMBEDDING_MODEL=gemini-embedding-001

# API key — one of these:
#   Gemini:  get free key at https://aistudio.google.com/apikey
#   OpenAI:  https://platform.openai.com/api-keys
HARNESS_EMBEDDING_API_KEY=

# Custom endpoint (only for openai-compatible, leave empty for default)
# HARNESS_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings

# Embedding request timeout in seconds
# HARNESS_EMBEDDING_TIMEOUT=30

# ──────────────────────────────────────────────
# Ingest Pipeline
# ──────────────────────────────────────────────

# Maximum file size in bytes (default: 50MB)
# HARNESS_MAX_FILE_SIZE=52428800

# Chunk size in characters (default: 1000)
# HARNESS_CHUNK_SIZE=1000

# Chunk overlap in characters (default: 200)
# HARNESS_CHUNK_OVERLAP=200

# ──────────────────────────────────────────────
# Retrieval (Phase 3 — not yet implemented)
# ──────────────────────────────────────────────

# Default retrieval top-k (1-10)
# HARNESS_TOP_K=5
